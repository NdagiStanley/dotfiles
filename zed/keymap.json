// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Terminal",
    "unbind": {
      "alt-b": [
        "terminal::SendText",
        "b"
      ]
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-b": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-r": "workspace::ToggleRightDock"
    }
  },
  {
    "bindings": {
      "alt-n": "multi_workspace::NextThread"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-g": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-shift-g": "git_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "alt-shift-g": "git_graph::Open"
    }
  },
  {
    "bindings": {
      "alt-t": "workspace::ToggleZoom"
    }
  },
  {
    "unbind": {
      "shift-escape": "workspace::ToggleZoom"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-shift-s": "workspace::SaveAs"
    }
  }
]
